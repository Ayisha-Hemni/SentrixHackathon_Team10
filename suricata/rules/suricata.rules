                         
# ICMP Recon
alert icmp any any -> any any (msg:"ICMP reconnaissance detected"; sid:1000001; rev:1;)

# SSH Attempt
alert tcp any any -> any 22 (msg:"SSH connection attempt detected"; flags:S; flow:stateless; si>

# HTTP Traffic
alert tcp any any -> any 80 (msg:"HTTP traffic detected"; flow:to_server,established; sid:10000>

# SYN Scan Detection
alert tcp any any -> any any (msg:"Possible SYN scan detected"; flags:S; flow:stateless; detect>

# SSH Brute Force Pattern
alert tcp any any -> any 22 (msg:"Possible SSH brute force detected"; flags:S; detection_filter>




