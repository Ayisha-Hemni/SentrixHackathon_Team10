# =========================================================

# ATTACK DETECTED - NMAP PORT SCAN

# =========================================================

alert tcp any any -> any any 
(msg:"ATTACK DETECTED - NMAP Port Scan"; 
flags:S; 
threshold:type both, track by_src, count 20, seconds 5; 
sid:1000001; rev:2;)

# =========================================================

# ATTACK DETECTED - SSH BRUTE FORCE (HYDRA)

# =========================================================

alert tcp any any -> any 22 
(msg:"ATTACK DETECTED - SSH Brute Force"; 
threshold:type both, track by_src, count 5, seconds 60; 
sid:1000002; rev:2;)

